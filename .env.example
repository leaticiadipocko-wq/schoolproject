# ─────────────────────────────────────────────────────────────
# SIARM — Environment configuration template
# Copy this file to .env.local and fill in the values to enable
# the production Firebase real-time backend for IUGET.
#
# When VITE_FIREBASE_API_KEY is empty OR VITE_DEMO_MODE=true,
# SIARM runs in DEMO_MODE: localStorage-backed mock data,
# no Firebase calls.
# ─────────────────────────────────────────────────────────────

# Hard switch — set to true to force demo mode even with keys present.
VITE_DEMO_MODE=true

# ─── Firebase project credentials ────────────────────────────
# Get these from the Firebase console:
#   https://console.firebase.google.com → Project settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=iuget-siarm.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=iuget-siarm
VITE_FIREBASE_STORAGE_BUCKET=iuget-siarm.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Optional: payment provider configuration ────────────────
# In production these would point to MTN MoMo / Orange Money sandbox
# or live endpoints. Demo mode short-circuits to localStorage.
VITE_MTN_MOMO_API_BASE=
VITE_MTN_MOMO_SUBSCRIPTION_KEY=
VITE_ORANGE_MONEY_API_BASE=
VITE_ORANGE_MONEY_CLIENT_ID=

# ─── Optional: institution branding ──────────────────────────
VITE_INSTITUTION_NAME="Institut Universitaire du Golfe de Guinée"
VITE_INSTITUTION_SHORT="IUGET"
VITE_INSTITUTION_MOTTO="Bien choisir c'est déjà réussir"
VITE_INSTITUTION_CAMPUS="Bonabéri · Douala"
