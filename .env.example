# Firebase config — get these from your Firebase console
# https://console.firebase.google.com/ → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# Anthropic API key for the AI chatbot
# https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxx

# Demo mode: when true, the app uses local mock data instead of Firebase
# Useful for development and defense demo without setting up Firebase
VITE_DEMO_MODE=true
